// Prisma schema for Remember app
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================================================
// User & Authentication
// ============================================================================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String?   // Null if using OAuth only
  name          String?
  avatarUrl     String?

  // Email verification
  emailVerified Boolean   @default(false)
  verifyToken   String?

  // Trial & Subscription
  trialEndsAt   DateTime?
  plan          Plan      @default(FREE)

  // Timestamps
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  lastLoginAt   DateTime?

  // Relations
  oauthAccounts OAuthAccount[]
  connectedPlatforms ConnectedPlatform[]
  contents      Content[]
  reviews       Review[]
  quizSessions  QuizSession[]
  settings      UserSettings?
  pushTokens    PushToken[]
  themes        Theme[]

  @@index([email])
}

model UserSettings {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Review preferences
  dailyReminderTime String  @default("09:00")
  timezone          String  @default("UTC")
  newCardsPerDay    Int     @default(20)

  // Notifications
  emailReminders    Boolean @default(true)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

enum Plan {
  FREE
  PRO
  LIFETIME
}

// OAuth accounts for user signup (Google, etc.)
model OAuthAccount {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  provider      String   // 'google'
  providerAccountId String

  createdAt     DateTime @default(now())

  @@unique([provider, providerAccountId])
  @@index([userId])
}

// ============================================================================
// Connected Platforms (YouTube, Spotify)
// ============================================================================

model ConnectedPlatform {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  platform      Platform

  // Content source selection (what to sync)
  sourceType    ContentSourceType?  // null = use platform default

  // OAuth tokens (encrypted)
  accessToken   String
  refreshToken  String?
  expiresAt     DateTime?

  // Sync tracking
  lastSyncAt    DateTime?
  lastSyncError String?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([userId, platform])
  @@index([userId])
  @@index([platform])
}

enum Platform {
  YOUTUBE
  SPOTIFY
  TIKTOK
  INSTAGRAM
}

// Content source type - what content to sync from each platform
enum ContentSourceType {
  // YouTube sources
  YOUTUBE_LIKES       // Liked videos (default)
  YOUTUBE_WATCH_LATER // Watch Later playlist

  // Spotify sources
  SPOTIFY_SAVED       // Saved podcast episodes (default)
  SPOTIFY_RECENT      // Recently played episodes

  // TikTok sources
  TIKTOK_LIKES        // Liked videos (only option)

  // Instagram sources
  INSTAGRAM_SAVED     // Saved reels only
  INSTAGRAM_LIKED     // Liked reels only
  INSTAGRAM_BOTH      // Both saved and liked (default)
}

// ============================================================================
// Content & Transcripts
// ============================================================================

model Content {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  platform      Platform
  externalId    String   // YouTube video ID or Spotify episode ID
  url           String

  // Metadata
  title         String
  description   String?
  thumbnailUrl  String?
  duration      Int?     // in seconds
  channelName   String?  // YouTube channel name, Spotify show name, TikTok/Instagram author

  // For Spotify podcasts
  showName       String?
  listenProgress Int?      // Listening progress percentage (0-100)
  fullyPlayed    Boolean   @default(false)

  // For TikTok/Instagram videos
  authorUsername String?   // TikTok/Instagram @username
  viewCount      Int?      // Number of views
  likeCount      Int?      // Number of likes (Instagram/TikTok)
  commentCount   Int?      // Number of comments (Instagram/TikTok)

  // Processing status
  status        ContentStatus @default(PENDING)
  transcriptionFailed Boolean @default(false) // True if no subtitles available

  // Timestamps
  capturedAt    DateTime // When user liked/played it
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  transcript    Transcript?
  quizzes       Quiz[]
  tags          Tag[]    @relation("ContentTags")

  contentThemes ContentTheme[]

  // Global transcript cache reference
  transcriptCacheId String?
  transcriptCache   TranscriptCache? @relation(fields: [transcriptCacheId], references: [id])

  @@unique([userId, platform, externalId])
  @@index([userId])
  @@index([status])
  @@index([platform, status])
}

enum ContentStatus {
  INBOX         // Just imported, pending triage
  ARCHIVED      // User archived, no quiz generation
  PENDING       // Legacy - migrated to SELECTED
  SELECTED      // User wants to learn, pending transcription
  TRANSCRIBING  // Transcription in progress
  GENERATING    // Quiz generation in progress
  READY         // Quiz ready
  FAILED        // Processing failed
  UNSUPPORTED   // Spotify Exclusive, etc.
}

model Transcript {
  id          String   @id @default(cuid())
  contentId   String   @unique
  content     Content  @relation(fields: [contentId], references: [id], onDelete: Cascade)

  text        String   // Full transcript text
  segments    Json?    // Timestamped segments [{ start, duration, text }]
  language    String   @default("en")

  // Processing info
  source      TranscriptSource

  createdAt   DateTime @default(now())
}

enum TranscriptSource {
  YOUTUBE_SUBTITLES  // Free via youtube-transcript-api
  WHISPER            // Paid via Whisper API
}

// ============================================================================
// Global Transcript Cache (shared across users)
// ============================================================================

model TranscriptCache {
  id            String   @id @default(cuid())

  platform      Platform
  externalId    String   // YouTube video ID, Spotify episode ID, etc.

  // Transcript data
  text          String?
  segments      Json?    // Timestamped segments [{ start, duration, text }]
  language      String?
  source        TranscriptSource?

  // Status and retry logic
  status        TranscriptCacheStatus @default(PENDING)
  failureReason String?
  attemptCount  Int      @default(0)
  lastAttemptAt DateTime?
  nextRetryAt   DateTime?  // Retry after X days if UNAVAILABLE

  // Lock for race condition prevention
  lockedBy      String?    // Worker ID
  lockedAt      DateTime?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  contents      Content[]

  @@unique([platform, externalId])
  @@index([status, nextRetryAt])
  @@index([lockedBy, lockedAt])
}

enum TranscriptCacheStatus {
  PENDING      // Not yet attempted
  PROCESSING   // In progress (locked by a worker)
  SUCCESS      // Transcript available
  UNAVAILABLE  // No subtitles available (retry in 7 days)
  FAILED       // Transient error (retry with backoff)
}

// ============================================================================
// Quiz & Spaced Repetition
// ============================================================================

model Quiz {
  id          String   @id @default(cuid())
  contentId   String?
  content     Content? @relation(fields: [contentId], references: [id], onDelete: Cascade)

  themeId     String?
  theme       Theme?   @relation(fields: [themeId], references: [id], onDelete: Cascade)
  isSynthesis Boolean  @default(false)

  question    String
  type        QuizType
  options     Json     // ["A) ...", "B) ...", ...]
  correctAnswer String // "A", "B", etc.
  explanation String?

  createdAt   DateTime @default(now())

  // Spaced repetition
  cards       Card[]

  @@index([contentId])
  @@index([themeId])
}

enum QuizType {
  MULTIPLE_CHOICE
  TRUE_FALSE
  FLASHCARD
}

model Card {
  id          String   @id @default(cuid())
  quizId      String
  quiz        Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
  userId      String

  // SM-2 Algorithm fields
  easeFactor  Float    @default(2.5)
  interval    Int      @default(1)   // days
  repetitions Int      @default(0)

  // Scheduling
  nextReviewAt DateTime @default(now())

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  reviews     Review[]

  @@unique([quizId, userId])
  @@index([userId, nextReviewAt])
}

model Review {
  id          String   @id @default(cuid())
  cardId      String
  card        Card     @relation(fields: [cardId], references: [id], onDelete: Cascade)
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Optional session tracking
  sessionId   String?
  session     QuizSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  rating      Rating
  responseTime Int?    // milliseconds

  createdAt   DateTime @default(now())

  @@index([userId, createdAt])
  @@index([sessionId])
}

enum Rating {
  AGAIN  // 1 - Complete blackout
  HARD   // 2 - Incorrect but remembered
  GOOD   // 3 - Correct with effort
  EASY   // 4 - Perfect recall
}

// ============================================================================
// Tags
// ============================================================================

model Tag {
  id          String    @id @default(cuid())
  name        String    @unique
  contents    Content[] @relation("ContentTags")
  themeTags   ThemeTag[]

  createdAt   DateTime  @default(now())

  @@index([name])
}

// ============================================================================
// Themes
// ============================================================================

model Theme {
  id            String         @id @default(cuid())
  userId        String
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  name          String
  slug          String
  color         String         @default("#6366F1")
  emoji         String         @default("📚")
  memo          String?
  memoGeneratedAt DateTime?
  discoveredAt  DateTime?     // null = pending discovery, set = user confirmed
  contentThemes ContentTheme[]
  themeTags     ThemeTag[]
  quizzes       Quiz[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@unique([userId, slug])
  @@unique([userId, name])
  @@index([userId])
}

model ContentTheme {
  id          String   @id @default(cuid())
  contentId   String
  content     Content  @relation(fields: [contentId], references: [id], onDelete: Cascade)
  themeId     String
  theme       Theme    @relation(fields: [themeId], references: [id], onDelete: Cascade)
  assignedAt  DateTime @default(now())
  assignedBy  String   @default("system")

  @@unique([contentId, themeId])
  @@index([themeId])
  @@index([contentId])
}

model ThemeTag {
  id       String @id @default(cuid())
  themeId  String
  theme    Theme  @relation(fields: [themeId], references: [id], onDelete: Cascade)
  tagId    String
  tag      Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([themeId, tagId])
  @@index([themeId])
  @@index([tagId])
}

// ============================================================================
// Quiz Sessions (Customizable Review Sessions)
// ============================================================================

model QuizSession {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Configuration
  questionLimit Int?      // null = unlimited
  platforms     Platform[] // Filter by platform (empty = all)
  tagIds        String[]  // Filter by tag IDs
  contentIds    String[]  // Specific content selection (empty = all matching)
  mode          String    @default("practice") // 'practice' = all cards, 'due' = only scheduled cards

  // Results
  startedAt     DateTime  @default(now())
  completedAt   DateTime?
  correctCount  Int       @default(0)
  totalCount    Int       @default(0)

  // AI Memo (generated on request)
  aiMemo        String?
  memoGeneratedAt DateTime?

  reviews       Review[]

  @@index([userId, startedAt])
}

// ============================================================================
// Streak Tracking
// ============================================================================

model Streak {
  id            String   @id @default(cuid())
  userId        String   @unique

  currentStreak Int      @default(0)
  longestStreak Int      @default(0)
  lastReviewDate DateTime?

  updatedAt     DateTime @updatedAt
}

// ============================================================================
// Job Execution Tracking (Observability)
// ============================================================================

model JobExecution {
  id             String    @id @default(cuid())

  // Job identification
  jobName        String    // e.g., 'youtube-sync', 'quiz-generation'

  // Execution lifecycle
  status         JobStatus @default(RUNNING)
  triggerSource  TriggerSource @default(SCHEDULED)
  startedAt      DateTime  @default(now())
  completedAt    DateTime?
  duration       Int?      // milliseconds

  // Processing metrics
  itemsProcessed Int?      // count of items processed (videos synced, quizzes generated, etc.)

  // Error tracking
  error          String?   // Error message if failed
  errorStack     String?   // Stack trace for debugging

  @@index([jobName, startedAt])
  @@index([status, startedAt])
  @@map("job_executions")
}

enum JobStatus {
  RUNNING
  SUCCESS
  FAILED
}

enum TriggerSource {
  SCHEDULED
  MANUAL
}

// ============================================================================
// Push Notification Tokens (multi-device support)
// ============================================================================

model PushToken {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  token       String   // Expo push token (ExponentPushToken[xxx])
  deviceId    String?  // Optional device identifier for deduplication

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, token])
  @@index([userId])
}
