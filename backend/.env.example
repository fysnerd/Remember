# ==============================================================================
# Remember Backend - Environment Variables
# ==============================================================================
# Copy this file to .env and fill in your values

# Server
PORT=3000
NODE_ENV=development

# Database (PostgreSQL or Supabase)
# For local: postgresql://remember:remember_dev_password@localhost:5432/remember
# For Supabase: postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_URL="postgresql://remember:remember_dev_password@localhost:5432/remember?schema=public"

# Redis (for caching and sessions)
REDIS_URL="redis://localhost:6379"

# ==============================================================================
# Authentication
# ==============================================================================

# JWT Secrets (generate strong random strings for production!)
JWT_SECRET="your-super-secret-jwt-key-change-in-production-min-32-chars"
JWT_EXPIRES_IN="7d"
JWT_REFRESH_SECRET="your-refresh-token-secret-change-in-production-min-32-chars"
JWT_REFRESH_EXPIRES_IN="30d"

# Google OAuth (for user signup with Google) - OPTIONAL
# Create at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_CALLBACK_URL="http://localhost:3000/api/auth/google/callback"

# ==============================================================================
# Platform OAuth (for content sync) - OPTIONAL for testing
# ==============================================================================

# YouTube OAuth (for accessing liked videos)
# Use same Google Cloud project, enable YouTube Data API v3
YOUTUBE_CLIENT_ID=""
YOUTUBE_CLIENT_SECRET=""
YOUTUBE_CALLBACK_URL="http://localhost:3000/api/oauth/youtube/callback"

# Spotify OAuth (for accessing podcast history)
# Create at: https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=""
SPOTIFY_CLIENT_SECRET=""
SPOTIFY_CALLBACK_URL="http://localhost:3000/api/oauth/spotify/callback"

# ==============================================================================
# AI / LLM Services (choose ONE provider)
# ==============================================================================

# LLM Provider: openai, mistral, or anthropic
LLM_PROVIDER="mistral"

# OpenAI API (GPT-4 for quiz generation, Whisper for transcription)
# Get key at: https://platform.openai.com/api-keys
# Models: gpt-4-turbo-preview
OPENAI_API_KEY=""

# Mistral API (RECOMMENDED - best price/quality ratio)
# Get key at: https://console.mistral.ai/api-keys
# Models: mistral-small-latest (~0.25€/1M tokens)
MISTRAL_API_KEY=""

# Anthropic API (Claude)
# Get key at: https://console.anthropic.com/settings/keys
# Models: claude-3-haiku (fast & cheap)
ANTHROPIC_API_KEY=""

# Listen Notes API (optional - for podcast RSS feed lookup)
# Get key at: https://www.listennotes.com/api/
LISTEN_NOTES_API_KEY=""

# ==============================================================================
# Email (for daily reminders) - OPTIONAL
# ==============================================================================

# Resend API (for sending emails)
# Get key at: https://resend.com/api-keys
RESEND_API_KEY=""
EMAIL_FROM="Remember <noreply@yourdomain.com>"

# ==============================================================================
# Payments (Stripe) - OPTIONAL
# ==============================================================================

# Stripe API
# Get keys at: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# Stripe Price IDs (create products in Stripe Dashboard)
STRIPE_PRICE_MONTHLY=""
STRIPE_PRICE_YEARLY=""

# ==============================================================================
# Frontend
# ==============================================================================

# Frontend URL (for CORS and OAuth redirects)
FRONTEND_URL="http://localhost:5173"
